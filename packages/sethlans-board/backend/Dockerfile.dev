# Immagine di sviluppo: a differenza del Dockerfile di produzione, qui il
# codice non viene copiato nell'immagine ma montato a runtime (vedi
# docker-dev-compose.yml), così le modifiche sono immediate grazie al
# --reload di uvicorn.
FROM python:3.12-slim

WORKDIR /app

COPY requirements.txt ./
RUN pip install --no-cache-dir -r requirements.txt

EXPOSE 9955

# Applica le migrazioni Alembic e avvia l'API con auto-reload sulle modifiche.
CMD ["sh", "-c", "alembic upgrade head && uvicorn server:app --host 0.0.0.0 --port 9955 --reload"]
