# URL del backend Board. Copiare in .env e modificare se serve.
VITE_API_URL=http://localhost:9955

# Sola lettura: in una prima versione la board è modificabile solo dagli
# Agenti AI (via HTTP), mai dall'utente dalla UI. Default: true.
# Mettere a false per riabilitare l'editing dall'interfaccia.
VITE_READONLY=true
